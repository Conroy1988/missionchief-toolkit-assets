{
  "compatibilityAliasManifest": ".github/asset-compatibility-aliases.json",
  "crossEndpointComparisons": [
    {
      "code": "distribution-body-mismatch",
      "description": "The Greasy Fork executable userscript body differs from the verified GitHub Release asset.",
      "field": "bodySha256",
      "left": "github-latest-userscript",
      "right": "greasyfork-install-userscript"
    }
  ],
  "excludedDirectories": [
    ".git",
    "node_modules",
    "release-bundle",
    "__pycache__"
  ],
  "excludedHosts": [
    "discord.com",
    "discordapp.com",
    "api.github.com"
  ],
  "explicitEndpoints": [
    {
      "compareLatestReleaseHash": true,
      "compareLatestReleaseVersion": true,
      "id": "github-latest-userscript",
      "kind": "userscript",
      "maxBytes": 2500000,
      "minBytes": 1000000,
      "required": true,
      "urlSource": {
        "jsonPointer": "/greasyFork/sourceUrl",
        "path": ".github/release-settings.json"
      }
    },
    {
      "compareLatestReleaseVersion": true,
      "id": "greasyfork-install-userscript",
      "kind": "userscript",
      "maxBytes": 2500000,
      "minBytes": 1000000,
      "required": true,
      "urlSource": {
        "jsonPointer": "/greasyFork/installUrl",
        "path": ".github/release-settings.json"
      }
    },
    {
      "compareLatestReleaseVersion": true,
      "id": "greasyfork-metadata",
      "kind": "metadata",
      "maxBytes": 50000,
      "minBytes": 40,
      "required": true,
      "urlSource": {
        "jsonPointer": "/greasyFork/metadataUrl",
        "path": ".github/release-settings.json"
      }
    },
    {
      "allowedWarningStatuses": [
        403,
        429
      ],
      "id": "greasyfork-project-page",
      "kind": "url",
      "required": false,
      "urlSource": {
        "jsonPointer": "/greasyFork/scriptUrl",
        "path": ".github/release-settings.json"
      }
    }
  ],
  "latestReleaseDashboard": "status/release-dashboard.json",
  "limits": {
    "maxEndpoints": 250
  },
  "mediaExtensions": {
    ".gif": {
      "contentTypes": [
        "image/gif",
        "application/octet-stream"
      ],
      "maxBytes": 15000000,
      "minBytes": 32
    },
    ".jpeg": {
      "contentTypes": [
        "image/jpeg",
        "application/octet-stream"
      ],
      "maxBytes": 15000000,
      "minBytes": 64
    },
    ".jpg": {
      "contentTypes": [
        "image/jpeg",
        "application/octet-stream"
      ],
      "maxBytes": 15000000,
      "minBytes": 64
    },
    ".json": {
      "contentTypes": [
        "application/json",
        "text/json",
        "text/plain",
        "application/octet-stream"
      ],
      "maxBytes": 5000000,
      "minBytes": 2,
      "repositoryAsset": false
    },
    ".mp3": {
      "contentTypes": [
        "audio/mpeg",
        "audio/mp3",
        "application/octet-stream"
      ],
      "maxBytes": 30000000,
      "minBytes": 1024
    },
    ".ogg": {
      "contentTypes": [
        "audio/ogg",
        "application/ogg",
        "application/octet-stream"
      ],
      "maxBytes": 30000000,
      "minBytes": 512
    },
    ".png": {
      "contentTypes": [
        "image/png",
        "application/octet-stream"
      ],
      "maxBytes": 15000000,
      "minBytes": 64
    },
    ".svg": {
      "contentTypes": [
        "image/svg+xml",
        "text/xml",
        "application/xml",
        "text/plain",
        "application/octet-stream"
      ],
      "maxBytes": 5000000,
      "minBytes": 32
    },
    ".wav": {
      "contentTypes": [
        "audio/wav",
        "audio/x-wav",
        "audio/wave",
        "application/octet-stream"
      ],
      "maxBytes": 30000000,
      "minBytes": 1024
    },
    ".webp": {
      "contentTypes": [
        "image/webp",
        "application/octet-stream"
      ],
      "maxBytes": 15000000,
      "minBytes": 32
    }
  },
  "monitoredHosts": [
    "raw.githubusercontent.com",
    "update.greasyfork.org"
  ],
  "network": {
    "maxBytesPerAsset": 30000000,
    "retries": 3,
    "retryBackoffSeconds": 2,
    "signatureBytes": 65536,
    "timeoutSeconds": 30,
    "userAgent": "MissionChief-Toolkit-Asset-Health/1.0 (+https://github.com/Conroy1988/missionchief-toolkit-assets)"
  },
  "repository": {
    "stableRef": "main"
  },
  "revision": "2026-07-17-audio-compatibility-aliases",
  "scanFiles": [
    "src/MissionChief_Map_Command_Toolkit.user.js",
    ".github/release-settings.json",
    "README.md",
    "status/README.md",
    "status/release-dashboard.json"
  ],
  "scanTextExtensions": [
    ".js",
    ".json",
    ".md",
    ".yml",
    ".yaml"
  ],
  "schemaVersion": 1,
  "scriptContentTypes": [
    "application/javascript",
    "text/javascript",
    "application/x-javascript",
    "text/plain",
    "application/octet-stream",
    "text/x-userscript",
    "text/x-userscript-meta"
  ]
}
