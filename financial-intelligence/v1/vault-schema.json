{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Conroy1988/missionchief-toolkit-assets/main/financial-intelligence/v1/vault-schema.json",
  "title": "MissionChief Financial Vault Envelope",
  "type": "object",
  "required": ["schema", "player", "deviceId", "syncRevision", "transactions"],
  "properties": {
    "schema": {"const": 1},
    "player": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {"type": ["string", "null"], "maxLength": 64},
        "name": {"type": "string", "maxLength": 120}
      },
      "additionalProperties": false
    },
    "deviceId": {"type": "string", "maxLength": 80},
    "syncRevision": {"type": "integer", "minimum": 0},
    "coverageStartMs": {"type": ["integer", "null"]},
    "coverageEndMs": {"type": ["integer", "null"]},
    "transactions": {
      "type": "array",
      "maxItems": 100000,
      "items": {
        "type": "object",
        "required": ["fingerprint", "timestamp", "amount", "description"],
        "properties": {
          "fingerprint": {"type": "string", "maxLength": 120},
          "timestamp": {"type": "integer"},
          "amount": {"type": "integer"},
          "description": {"type": "string", "maxLength": 500},
          "dateLabel": {"type": "string", "maxLength": 120},
          "sourceKey": {"type": "string", "maxLength": 700},
          "occurrence": {"type": "integer", "minimum": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
