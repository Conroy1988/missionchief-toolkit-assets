ue #378 renderer baseline drifted: {headroom.get('expectedSourceLines')} != {base_lines}")
headroom["approvedNonStyleChanges"].append({"issue": 378, "phase": "enhanced-requirements-renderer", "lines": delta})
headroom["approvedNonStyleSourceLines"] = sum(change["lines"] for change in headroom["approvedNonStyleChanges"])
headroom["expectedSourceLines"] = new_lines
HEADROOM_FIXTURE.write_text(json.dumps(headroom, indent=2) + "\n", encoding="utf-8")

if DIAGNOSTIC.exists():
    DIAGNOSTIC.unlink()

subprocess.run(["node", "--check", str(SOURCE)], cwd=ROOT, check=True)
subprocess.run(["node", str(ENGINE_TEST)], cwd=ROOT, check=True)
subprocess.run([sys.executable, str(SHELL_TEST)], cwd=ROOT, check=True)
subprocess.run([sys.executable, str(RENDERER_TEST)], cwd=ROOT, check=True)
subprocess.run([sys.executable, str(HEADROOM_TEST)], cwd=ROOT, check=True)
print(f"Issue #378 enhanced requirements renderer applied with exact source delta {delta}.")
